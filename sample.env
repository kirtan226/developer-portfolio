# Django
SECRET_KEY=demo-secret-key-change-me
ADMIN_URL=admin/
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
SERVER=local
TRACK_SITE_VISIT_DURATION=True
SITE_VISIT_ALERT_DELAY_SECONDS=10
SQLITE_TIMEOUT_SECONDS=1
HOME_CONTEXT_CACHE_SECONDS=86400

# Superuser
# Use with:
# python manage.py createsuperuser --noinput
# or:
# python manage.py create_env_superuser
DJANGO_SUPERUSER_USERNAME=kirtan
DJANGO_SUPERUSER_EMAIL=your@email.com
DJANGO_SUPERUSER_PASSWORD=StrongPassword123

# Database
# SERVER=local uses PostgreSQL with these values.
# SERVER=live uses SQLite at db.sqlite3 and ignores these values.
DB_NAME=developer_portfolio
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# Email notifications
EMAIL_HOST_USER=demo@example.com
EMAIL_HOST_PASSWORD=demo-email-app-password
EMAIL_TIMEOUT_SECONDS=10

# Telegram notifications
SEND_TELEGRAM_ALERTS=True
TELEGRAM_BOT_TOKEN=demo-telegram-bot-token
TELEGRAM_CHAT_ID=demo-telegram-chat-id
