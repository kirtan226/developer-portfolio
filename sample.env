# Django
SECRET_KEY=demo-secret-key-change-me
ADMIN_URL=admin/
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
SERVER=local

# Database
# SERVER=local uses PostgreSQL with these values.
# SERVER=live uses SQLite at db.sqlite3 and ignores these values.
DB_NAME=developer_portfolio
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# Email notifications
EMAIL_HOST_USER=demo@example.com
EMAIL_HOST_PASSWORD=demo-email-app-password

# Telegram notifications
TELEGRAM_BOT_TOKEN=demo-telegram-bot-token
TELEGRAM_CHAT_ID=demo-telegram-chat-id
